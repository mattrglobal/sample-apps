{
	"name": "interaction-hook-app",
	"version": "0.1.0",
	"private": true,
	"overrides": {
		"glob": "^10.5.0"
	},
	"scripts": {
		"dev": "concurrently -k -n \"TUNNEL,APP\" -c \"cyan,green\" \"node src/tunnel.mjs\" \"node src/check-port.mjs && next dev -p ${PORT:-7313}\"",
		"dev:app": "node src/check-port.mjs && next dev -p ${PORT:-7313}",
		"build": "next build",
		"start": "next start",
		"lint": "next lint"
	},
	"dependencies": {
		"@ngrok/ngrok": "^1.5.2",
		"dotenv": "^16.6.1",
		"jose": "^5.2.0",
		"next": "16.1.7",
		"react": "^18",
		"react-dom": "^18",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@types/node": "^20",
		"@types/react": "^18",
		"@types/react-dom": "^18",
		"autoprefixer": "^10.0.1",
		"baseline-browser-mapping": "^2.10.8",
		"concurrently": "^9.2.1",
		"eslint": "^9",
		"eslint-config-next": "16.1.5",
		"postcss": "^8",
		"tailwindcss": "^3.3.0",
		"typescript": "^5"
	}
}
