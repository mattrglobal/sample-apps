# MATTR VII Interaction Hook Configuration
# Copy to .env and replace with your values

# Secret provided by MATTR VII when creating the interaction hook (base64 encoded)
INTERACTION_HOOK_SECRET="YOUR_BASE64_SECRET_FROM_MATTR_VII"

# Your application URL (use ngrok URL for local dev)
APP_URL="https://[your-app-domain]"

# MATTR VII tenant URL
ISSUER_TENANT_URL="https://[your-tenant].vii.[region].mattr.global"

# ngrok auth token for automatic tunnel setup
NGROK_AUTHTOKEN=

# Port for the development server
PORT=7313
